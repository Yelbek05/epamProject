{
  "name": "epamproject",
  "version": "1.0.0",
  "description": "JS automated testing project with pattern POM in WDIO",
  "main": "wdio.conf.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:report": "npm run wdio && npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/cli": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1",
    "@wdio/visual-service": "^9.2.0",
    "allure-commandline": "^2.38.1",
    "chromedriver": "^146.0.5",
    "edgedriver": "^6.3.0",
    "geckodriver": "^6.1.0"
  },
  "author": "",
  "license": "ISC"
}
